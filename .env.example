# Minecraft 服务器配置
MINECRAFT_SERVER_URL=http://localhost:8080

# HMAC-Timestamp 密钥（32字节hex）
# 使用以下命令生成：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_SECRET=

# 建筑服务器 API 地址（可选，不设置则使用 MINECRAFT_SERVER_URL）
BUILDINGS_SERVER_URL=http://your-buildings-server:8080

# 建筑服务器 TOTP 密钥（可选，不设置则使用 TOTP_SECRET）
BUILDINGS_TOTP_SECRET=